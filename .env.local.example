# URL dasar API Django (TANPA trailing slash) -- ganti sesuai environment.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1

# WAJIB diisi acak/rahasia (buat dgn `openssl rand -base64 32`) -- dipakai
# NextAuth enkripsi session/JWT-nya SENDIRI (beda dari JWT secret Django).
NEXTAUTH_SECRET=

# URL frontend Next.js ini sendiri (dipakai NextAuth utk callback).
NEXTAUTH_URL=http://localhost:3000

# Google Maps JavaScript API key -- dipakai halaman "Gambar Polygon di Peta"
# (Mobile Pool Location). Buat di Google Cloud Console, aktifkan "Maps
# JavaScript API". Field ini PUBLIC (dikirim ke browser), bukan rahasia.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# WebSocket base URL utk real-time update halaman Active Device (Django
# Channels, endpoint /ws/iclock) -- BEDA dari NEXT_PUBLIC_API_BASE_URL
# (yang itu utk REST API biasa, ws:// / wss:// butuh skema beda + biasanya
# TIDAK di bawah path /api/v1). Pakai ws:// utk dev (http biasa), wss://
# kalau server API sudah HTTPS (nginx SSL terminasi, dsb).
NEXT_PUBLIC_WS_BASE_URL=ws://127.0.0.1:8000
